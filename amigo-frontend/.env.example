# ============================================================
# Amigo Frontend — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit the actual .env.local file to git.
# ============================================================

# Backend REST API base URL (no trailing slash)
# Local development:
VITE_API_URL=http://localhost:5000

# Backend Socket.IO server URL
VITE_SOCKET_SERVER=http://localhost:5000

# Production (replace with your deployed backend URL):
# VITE_API_URL=https://your-backend.onrender.com
# VITE_SOCKET_SERVER=https://your-backend.onrender.com
