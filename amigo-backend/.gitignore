# ============================================================
# Amigo Backend — .gitignore
# ============================================================

# --- SECURITY: NEVER commit real environment files ---
.env
.env.local
.env.*.local
# .env.example is safe to commit (contains no real secrets)

# Dependencies
node_modules/*

# Build output
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
